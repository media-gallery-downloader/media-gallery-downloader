<?xml version="1.0"?>
<ruleset name="MGD PHPMD ruleset"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>
        PHPMD ruleset tuned for a Laravel 12 / Filament 3 codebase. Keeps the
        high-signal rules and drops the ones that produce noise against Laravel
        idioms (facades/static access, framework method signatures, short loop
        and closure variables). Run locally with: phpmd app text phpmd.xml
    </description>

    <!-- Clean Code: keep most, drop Laravel-hostile rules -->
    <rule ref="rulesets/cleancode.xml">
        <!-- Laravel facades and the Eloquent/query builder rely on static access -->
        <exclude name="StaticAccess"/>
        <!-- Boolean flags are common in framework option arrays and signatures -->
        <exclude name="BooleanArgumentFlag"/>
        <!-- Else is sometimes the clearest control flow -->
        <exclude name="ElseExpression"/>
    </rule>

    <!-- Code Size: full ruleset (this was the only set the workflow used before) -->
    <rule ref="rulesets/codesize.xml"/>

    <!-- Design -->
    <rule ref="rulesets/design.xml">
        <!-- Controllers/services legitimately coordinate many collaborators -->
        <exclude name="CouplingBetweenObjects"/>
    </rule>

    <!-- Naming: drop length-based rules ($id, $e, find(), etc.) -->
    <rule ref="rulesets/naming.xml">
        <exclude name="ShortVariable"/>
        <exclude name="LongVariable"/>
        <exclude name="ShortMethodName"/>
    </rule>

    <!-- Unused Code: high signal for dead code -->
    <rule ref="rulesets/unusedcode.xml">
        <!-- Framework callbacks and interface methods often have unused params -->
        <exclude name="UnusedFormalParameter"/>
    </rule>

</ruleset>
